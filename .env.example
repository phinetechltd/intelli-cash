# API
DATABASE_URL="file:./dev.db"
API_PORT=4000
# Comma-separated browser origins allowed to call the API with cookies.
WEB_ORIGIN="http://localhost:3000,http://localhost:3001"
API_PUBLIC_URL="http://localhost:4000"
SESSION_SECRET="replace-with-a-long-random-secret"
ALLOW_SANDBOX_NETWORK_TESTS=false
ENABLE_PAYMENT_NETWORK_CALLS=false
GOOGLE_MAPS_BROWSER_API_KEY=

# IntelliAudit AI
INTELLIAUDIT_LLM_PROVIDER=disabled
INTELLIAUDIT_LLM_BASE_URL=
INTELLIAUDIT_LLM_API_KEY=
INTELLIAUDIT_LLM_MODEL=
INTELLIAUDIT_ENABLE_CONNECTOR_NETWORK_CALLS=false

# Web
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Safaricom M-Pesa Daraja sandbox
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL="https://example.com/api/v1/payments/mpesa/stk-callback"
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=
MPESA_B2C_RESULT_URL="https://example.com/api/v1/payments/mpesa/b2c-result"
MPESA_B2C_TIMEOUT_URL="https://example.com/api/v1/payments/mpesa/b2c-timeout"

# Africa's Talking sandbox
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=

# Bonga SMS
BONGA_SMS_CLIENT_ID=
BONGA_SMS_API_KEY=
BONGA_SMS_API_SECRET=
BONGA_SMS_SERVICE_ID=1

# IPRS sandbox
IPRS_BASE_URL=
IPRS_CLIENT_ID=
IPRS_CLIENT_SECRET=

# KCB Buni sandbox
KCB_BUNI_BASE_URL=
KCB_BUNI_CLIENT_ID=
KCB_BUNI_CLIENT_SECRET=
KCB_BUNI_CALLBACK_URL="https://example.com/api/v1/integrations/kcb-buni/callback"

# Paystack test mode
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# TransUnion CRB sandbox
TRANSUNION_BASE_URL=
