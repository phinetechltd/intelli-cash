{
  "name": "@intellicash/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env DATABASE_URL=file:./dev.db tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "cross-env NODE_ENV=test DATABASE_URL=file:./dev.db vitest run",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "cross-env DATABASE_URL=file:./dev.db tsx prisma/ensure-schema.ts",
    "db:push:env": "tsx prisma/ensure-schema.ts",
    "db:reset": "cross-env DATABASE_URL=file:./dev.db tsx prisma/ensure-schema.ts --force && npm run db:seed",
    "db:seed": "cross-env DATABASE_URL=file:./dev.db tsx prisma/seed.ts",
    "db:seed:env": "tsx prisma/seed.ts",
    "import:ftma": "cross-env DATABASE_URL=file:./dev.db tsx prisma/import-ftma-workbook.ts"
  },
  "dependencies": {
    "@intellicash/shared": "*",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "cookie": "^1.0.2",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "read-excel-file": "^9.0.9",
    "tsx": "^4.22.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.2.1",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
